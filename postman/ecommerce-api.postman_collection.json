{
  "info": {
    "name": "E-Commerce API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "jwtToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "1" },
    { "key": "productId", "value": "1" },
    { "key": "orderId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ahmad\",\n  \"lastName\": \"Raza\",\n  \"email\": \"ahmad@example.com\",\n  \"password\": \"Password123!\",\n  \"phone\": \"+91 9876543210\",\n  \"role\": \"CUSTOMER\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"ahmad@example.com\",\n  \"password\": \"Password123!\"\n}"
        }
      }
    },
    {
      "name": "Auth - Refresh",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/refresh",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        }
      }
    },
    {
      "name": "Users - Get",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{jwtToken}}" }],
        "url": "{{baseUrl}}/api/v1/users/{{userId}}"
      }
    },
    {
      "name": "Users - Update",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/users/{{userId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ahmad\",\n  \"lastName\": \"Raza\",\n  \"email\": \"ahmad@example.com\",\n  \"phone\": \"+91 9876543210\",\n  \"role\": \"CUSTOMER\"\n}"
        }
      }
    },
    {
      "name": "Products - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/products",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Mechanical Keyboard\",\n  \"description\": \"Hot-swappable keyboard\",\n  \"price\": 129.99,\n  \"category\": \"Electronics\",\n  \"active\": true\n}"
        }
      }
    },
    {
      "name": "Products - List",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/products"
      }
    },
    {
      "name": "Inventory - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/inventory",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": {{productId}},\n  \"availableQuantity\": 50,\n  \"reservedQuantity\": 0\n}"
        }
      }
    },
    {
      "name": "Inventory - Update Stock",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/inventory/products/{{productId}}/stock",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"availableQuantity\": 100\n}"
        }
      }
    },
    {
      "name": "Orders - Place",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/orders",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": {{userId}},\n  \"idempotencyKey\": \"order-{{$timestamp}}\",\n  \"items\": [\n    { \"productId\": {{productId}}, \"quantity\": 2 }\n  ]\n}"
        }
      }
    },
    {
      "name": "Orders - Cancel",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{jwtToken}}" }],
        "url": "{{baseUrl}}/api/v1/orders/{{orderId}}/cancel"
      }
    },
    {
      "name": "Notifications - By User",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{jwtToken}}" }],
        "url": "{{baseUrl}}/api/v1/notifications/users/{{userId}}"
      }
    }
  ]
}
